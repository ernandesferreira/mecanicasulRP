# Variáveis de ambiente para Vercel Postgres
# Copie para .env.local em ambiente local

# Conexão pooled (Prisma Client)
POSTGRES_PRISMA_MECANICA_POSTGRES_URL="postgresql://user:password@host:5432/database?sslmode=require"

# Conexão non-pooled (migrations)
POSTGRES_PRISMA_MECANICA_POSTGRES_URL_NON_POOLING="postgresql://user:password@host:5432/database?sslmode=require"
